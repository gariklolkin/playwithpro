generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Placeholder model used to validate the migration pipeline end-to-end.
model HealthCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

enum Role {
  AMATEUR
  PROFESSIONAL
  ADMIN
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String? // null for OAuth-only accounts
  role            Role
  displayName     String
  locale          String    @default("en")
  timezone        String    @default("UTC")
  avatarKey       String? // S3 object key; public URL is computed, never stored
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  oauthAccounts      OAuthAccount[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  proProfile         ProProfile?
  playerProfile      PlayerProfile?
  videos             Video[]
}

enum PlayerLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPETITIVE
}

enum Handedness {
  LEFT
  RIGHT
}

enum Grip {
  SHAKEHAND
  PENHOLD
}

enum PlayingStyle {
  OFFENSIVE
  ALL_ROUND
  DEFENSIVE
}

/// Amateur-owned profile; 1:1 with an AMATEUR user. Created empty on first access.
model PlayerProfile {
  id                String      @id @default(uuid())
  userId            String      @unique
  level             PlayerLevel   @default(BEGINNER)
  style             PlayingStyle?
  yearsOfExperience Int?
  handedness        Handedness?
  grip              Grip?
  about             String      @default("")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VideoStatus {
  UPLOADING
  PROCESSING
  READY
  REJECTED
}

/// Amateur-uploaded game footage. The original object is never modified;
/// playbackKey may equal originalKey when the source is already browser-safe.
model Video {
  id              String      @id @default(uuid())
  ownerId         String
  title           String
  status          VideoStatus @default(UPLOADING)
  originalKey     String
  playbackKey     String?
  /// S3 multipart upload id; cleared once the upload completes or aborts.
  s3UploadId      String?
  sizeBytes       BigInt?
  durationSeconds Int?
  width           Int?
  height          Int?
  fps             Float?
  codec           String?
  container       String?
  /// Machine-readable reason key, localized in the UI.
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  owner           User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, createdAt])
  @@index([status, updatedAt])
}

model OAuthAccount {
  id                String @id @default(uuid())
  userId            String
  provider          String // "google"
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique // sha256 of the opaque token
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Single-use tokens for email verification and password reset.
model VerificationToken {
  id        String    @id @default(uuid())
  userId    String
  kind      String // "email_verify" | "password_reset"
  tokenHash String    @unique
  /// Wrong email-code entries; the code is burned after the limit.
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

enum ProProfileStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum ServiceType {
  VIDEO_ANALYSIS
  CONSULTATION
  GAME
}

enum VerificationState {
  AWAITING_SCHEDULING
  SCHEDULED
  IN_PROGRESS
  VERIFIED
  REJECTED
  CANCELLED
}

enum SlotStatus {
  OPEN
  BOOKED
  REMOVED
}

enum BookingStatus {
  SCHEDULED
  COMPLETED
  RESCHEDULED
  NO_SHOW
  CANCELLED_BY_PRO
  CANCELLED_BY_ADMIN
}

enum MeetingSyncStatus {
  PENDING
  SYNCED
  FAILED
}

/// Coach-owned public profile; 1:1 with a PROFESSIONAL user.
model ProProfile {
  id        String           @id @default(uuid())
  userId    String           @unique
  status    ProProfileStatus @default(DRAFT)
  bio       String           @default("") // single free-form "about" block; optional
  languages String[]         @default([]) // ISO 639-1, subset of platform locales
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  services             ProService[]
  verificationRequests VerificationRequest[]
  availabilityRules    AvailabilityRule[]
  availabilitySlots    AvailabilitySlot[]
}

model ProService {
  id         String      @id @default(uuid())
  profileId  String
  type       ServiceType
  priceMinor Int // money: integer minor units, never floats
  currency   String      @db.Char(3) // ISO 4217
  venueLabel String      @default("") // GAME only: club/address picked on the map
  venueLat   Float? // GAME only
  venueLng   Float? // GAME only
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  profile    ProProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, type])
}

/// Audit trail of verification submissions; the newest active one drives the flow.
model VerificationRequest {
  id           String            @id @default(uuid())
  profileId    String
  state        VerificationState @default(AWAITING_SCHEDULING)
  adminNote    String            @default("")
  noShowCount  Int               @default(0)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  profile      ProProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)

  bookings VerificationBooking[]

  @@index([state, createdAt])
}

/// Admin-published verification call slot. Times are UTC.
model VerificationSlot {
  id          String     @id @default(uuid())
  startsAt    DateTime
  endsAt      DateTime
  status      SlotStatus @default(OPEN)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bookings VerificationBooking[]

  @@index([status, startsAt])
}

enum AvailabilitySlotSource {
  RULE // materialized from the weekly template
  MANUAL // one-off slot added by the coach
}

/// Recurring weekly availability window in the coach's wall-clock time.
/// UTC conversion happens per concrete date at materialization, so local
/// times stay stable across DST transitions.
model AvailabilityRule {
  id          String     @id @default(uuid())
  profileId   String
  weekday     Int // 0 = Monday … 6 = Sunday (ISO)
  startMinute Int // minutes from local midnight; multiple of 30
  endMinute   Int // exclusive; endMinute - startMinute >= 60
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  profile     ProProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

/// Concrete bookable 60-minute coach slot. Times are UTC.
/// The unique (profileId, startsAt) pair anchors idempotent materialization:
/// existing rows — including REMOVED ones — are never duplicated or resurrected.
model AvailabilitySlot {
  id        String                 @id @default(uuid())
  profileId String
  startsAt  DateTime
  endsAt    DateTime
  status    SlotStatus             @default(OPEN)
  source    AvailabilitySlotSource @default(RULE)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  profile   ProProfile             @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, startsAt])
  @@index([profileId, status, startsAt])
}

/// One booking attempt per row; outcomes (no-show, cancellations) stay as audit trail.
/// A partial unique index (raw SQL in the migration) allows at most one
/// SCHEDULED booking per slot while keeping finished attempts as history.
model VerificationBooking {
  id                String              @id @default(uuid())
  slotId            String
  requestId         String
  status            BookingStatus       @default(SCHEDULED)
  googleEventId     String?
  meetUrl           String?
  syncStatus        MeetingSyncStatus   @default(PENDING)
  syncAttempts      Int                 @default(0)
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  slot              VerificationSlot    @relation(fields: [slotId], references: [id])
  request           VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([requestId])
  @@index([status, syncStatus])
}
