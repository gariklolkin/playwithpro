# --- PostgreSQL ---
POSTGRES_USER=topspin
POSTGRES_PASSWORD=topspin
POSTGRES_DB=topspin
# Used directly by apps/api when running outside Tilt/Compose (e.g. `pnpm prisma migrate dev`).
DATABASE_URL=postgresql://topspin:topspin@localhost:5432/topspin

# --- apps/api ---
NODE_ENV=development
PORT=4000
WEB_APP_URL=http://localhost:3000

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=topspin
MINIO_ROOT_PASSWORD=topspin123
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=topspin-videos
S3_ACCESS_KEY=topspin
S3_SECRET_KEY=topspin123

# --- Mailpit (local SMTP catcher) ---
SMTP_HOST=localhost
SMTP_PORT=1025
