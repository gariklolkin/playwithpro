# --- PostgreSQL ---
POSTGRES_USER=playwithpro
POSTGRES_PASSWORD=playwithpro
POSTGRES_DB=playwithpro
# Used directly by apps/api when running outside Tilt/Compose (e.g. `pnpm prisma migrate dev`).
DATABASE_URL=postgresql://playwithpro:playwithpro@localhost:5432/playwithpro

# --- apps/api ---
NODE_ENV=development
PORT=4000
WEB_APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- apps/web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
# API base URL for server-side fetches from the web app; inside Docker the API
# is reachable by service name (compose sets http://api:4000). Defaults to
# NEXT_PUBLIC_API_URL when unset.
#API_URL_INTERNAL=

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=playwithpro
MINIO_ROOT_PASSWORD=playwithpro123
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=playwithpro-videos
S3_ACCESS_KEY=playwithpro
S3_SECRET_KEY=playwithpro123

# --- Mailpit (local SMTP catcher) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=PlayWithPro <no-reply@playwithpro.local>

# --- Auth (apps/api) ---
# Secret for signing access JWTs. Generate a long random string for anything non-local.
JWT_ACCESS_SECRET=dev-only-change-me
# Google OAuth (leave empty to disable the Google sign-in routes locally).
# Create credentials at https://console.cloud.google.com/apis/credentials with
# redirect URI http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Dev admin seed (pnpm db:seed; dev only) ---
ADMIN_EMAIL=admin@playwithpro.local
ADMIN_PASSWORD=admin12345

# --- Verification scheduling: Google Calendar/Meet (apps/api) ---
# Leave all three empty locally: the API then uses a fake meeting provider with
# deterministic join URLs and no external calls.
# Production setup (see README "Verification call scheduling"):
#   1. Create a service account in Google Cloud, enable the Calendar API.
#   2. Grant it domain-wide delegation in the Workspace Admin console with
#      scope https://www.googleapis.com/auth/calendar.
#   3. GOOGLE_SA_KEY = the FULL service-account JSON key, as one line.
#   4. GOOGLE_IMPERSONATE_SUBJECT = the Workspace user that owns the
#      verification calendar (e.g. verify@yourdomain.com).
#   5. GOOGLE_CALENDAR_ID = that calendar's id (usually the same email).
#   6. In Workspace Admin > Apps > Google Meet, allow external/anonymous
#      participants to knock and join — coaches do NOT need Google accounts.
GOOGLE_SA_KEY=
GOOGLE_CALENDAR_ID=
GOOGLE_IMPERSONATE_SUBJECT=
